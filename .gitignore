# Node / Vite / React / TypeScript standard ignore
node_modules/

# Build output
dist/
build/
.out/
.next/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log

# Dependency directories caches
.pnpm-store/
.parcel-cache/
.cache/
.vite/

# Editor & OS
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# TypeScript
*.tsbuildinfo

# Environment & secrets
.env
.env.*
!.env.example

# Coverage / test output
coverage/
*.lcov

# Temporary files
/tmp
.temp/
*.tmp
*.bak
*.orig

# Misc
.sass-cache/
.eslintcache
.stylelintcache

# Local data
*.local.json

# Lottie / media processed caches
*.lottie-cache

# Windows specific
Desktop.ini
$RECYCLE.BIN/

# macOS
.AppleDouble
.LSOverride

# Yarn 2+ (if ever used)
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
