# Example Nginx config for libunand.siunand.my.id (Vite + React SPA)
# Copy (or merge) this into your /etc/nginx/sites-available/libunand and enable it.
# IMPORTANT: Adjust 'root' path to the directory that contains index.html (Vite build output /dist).

server {
    listen 80;
    server_name libunand.siunand.my.id;

    # Point this to your deployed Vite build directory
    # e.g. after copying dist/* to /var/www/libunand/current
    root /var/www/libunand/current;
    index index.html;
    charset utf-8;

    # --- GZIP (optional but recommended) ---
    gzip on;
    gzip_types text/plain text/css application/json application/javascript application/xml+rss application/xml image/svg+xml;
    gzip_min_length 1024;

    # --- Primary SPA fallback ---
    # Any path that is not a real file/folder will fallback to index.html so React Router can handle /admin, /admin/dashboard, etc.
    location / {
        try_files $uri $uri/ /index.html;
    }

    # --- Cache immutable hashed assets (Vite outputs hashed filenames) ---
    location ~* \.(?:js|mjs|css|woff2?|ttf|otf|eot)$ {
        try_files $uri =404;
        expires 30d;
        add_header Cache-Control "public, max-age=2592000, immutable";
        access_log off;
    }

    # Images & media
    location ~* \.(?:png|jpe?g|gif|webp|avif|svg|ico)$ {
        try_files $uri =404;
        expires 30d;
        add_header Cache-Control "public, max-age=2592000";
        access_log off;
    }

    # Do NOT aggressively cache index.html (ensures new deploy picked up)
    location = /index.html {
        add_header Cache-Control "no-cache, no-store, must-revalidate";
    }

    # Optional: Security headers (tune CSP as needed)
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
    add_header Permissions-Policy "camera=(), microphone=(), geolocation=()" always;
    # add_header Content-Security-Policy "default-src 'self'; img-src 'self' data:; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self';" always;

    # Basic health check endpoint (optional)
    location = /healthz { return 200 'ok'; add_header Content-Type text/plain; }

    # Error pages fallback to SPA (so deep refresh on non-existent file -> app 404 page later)
    error_page 404 /index.html;
    error_page 500 502 503 504 /index.html;
}

# If using HTTPS with Certbot, you will have another server block like:
# server {
#   listen 443 ssl http2;
#   server_name libunand.siunand.my.id;
#   ssl_certificate /etc/letsencrypt/live/libunand.siunand.my.id/fullchain.pem;
#   ssl_certificate_key /etc/letsencrypt/live/libunand.siunand.my.id/privkey.pem;
#   include /etc/letsencrypt/options-ssl-nginx.conf;
#   ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
#   # (repeat same inner locations as above) OR use include directive.
# }
